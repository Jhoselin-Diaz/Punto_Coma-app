{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ng serve (Arranque Directo)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "start"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Abrir en Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
